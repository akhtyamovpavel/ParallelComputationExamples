*build*
*.out

# Скомпилированные MPI-бинарники (рядом с run*.sh в bin/ каждого примера)
MPI/00-hello-world/bin/MpiHelloWorld
MPI/01-send_recv/bin/MpiSendRecv
MPI/02-ping-pong/bin/MpiPingPong
MPI/03-probe-message-status/bin/MpiProbe
MPI/03-probe-message-status/bin/MpiWithoutProbe
MPI/04-isend-irecv/bin/MpiIsendRecv
MPI/05-bcast/bin/MpiBcast
MPI/06-scatter-gather/bin/MpiScatterGather
MPI/07-reduce-allreduce/bin/MpiReduceAllreduce
MPI/08-alltoall/bin/MpiAlltoall
MPI/09-collective-benchmark/bin/MpiCollectiveBenchmark
MPI/10-comm-split/bin/MpiCommSplit
MPI/11-comm-dup/bin/MpiCommDup
MPI/12-comm-group/bin/MpiCommGroup
MPI/13-comm-cart/bin/MpiCommCart

# Скомпилированные OpenMP-бинарники (рядом с исходниками, без расширения)
OpenMP/00-hello-world/main

# Скомпилированные CUDA-бинарники (собираются прямо в директориях примеров).
# Большинство примеров даёт бинарник `main` рядом с main.cu.
CUDA/**/main

# Примеры с несколькими .cu в одной директории (02-shared, 04-reduction/00..01,
# 05-scan, 06-cublas) выдают бинарники с уникальными именами.
CUDA/03-memory-model/01-uncoalesced-access/Uncoalesced
CUDA/03-memory-model/02-shared/SharedGlobal
CUDA/03-memory-model/02-shared/SharedLocal
CUDA/04-reduction/00-stupid-sum/ReduceStupid
CUDA/04-reduction/00-stupid-sum/ReduceStupidNorm
CUDA/04-reduction/01-default-sum/ReduceDefault
CUDA/04-reduction/01-default-sum/ReduceNoShared
CUDA/05-scan/ScanNaiveCpu
CUDA/05-scan/ScanNaiveCuda
CUDA/05-scan/ScanCorrect
CUDA/05-scan/ScanRecursive
CUDA/05-scan/ScanTwoLayer
CUDA/05-scan/ScanBankConflicts
CUDA/06-cublas/CublasVectorAdd
CUDA/06-cublas/CublasVectorAdding
CUDA/06-cublas/CublasCosine
CUDA/06-cublas/CublasMatrixSums

# Скомпилированные OpenCL-бинарники (рядом с main.cpp, имя `main`).
OpenCL/**/main
