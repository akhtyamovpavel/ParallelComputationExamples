// square.cl — пример ядра, живущего в отдельном файле.
// В реальных проектах ядра всегда хранятся в .cl файлах:
// это даёт подсветку синтаксиса, удобное редактирование и
// возможность повторного использования из разных хост-программ.

__kernel void square(__global const float* in,
                     __global float* out,
                     const int n) {
    int i = get_global_id(0);
    if (i < n) {
        out[i] = in[i] * in[i];
    }
}
